---
import '@fontsource-variable/outfit';

interface Props {
	title?: string;
}

const { title = 'Aula Virtual' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen overflow-x-hidden bg-brand-dark text-white antialiased md:block" style="font-family: 'Outfit Variable', sans-serif;">
		<slot />
	</body>
</html>

<style is:global>
	@import '../styles/global.css';
</style>
